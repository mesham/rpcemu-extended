/machines/
/shared/

# Legacy single-machine state (CMOS now lives under machines/<name>/)
/cmos.ram
/rpc.cfg

# Local tool / editor settings
/.claude/

# Editor swap files / patch leftovers
*.swp
*~
*.orig
*.rej
*.bak
.DS_Store

# Upstream reference sources (Arculator etc.) - study only, never committed
/reference/
