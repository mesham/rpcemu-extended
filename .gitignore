# Build trees
/build/
/build-*/

# Release staging
/releases/

# Built binaries at project root
/rpcemu-recompiler
/rpcemu-interpreter
/rpcemu-recompiler-debug
/rpcemu-interpreter-debug
/rpcemu-*
/RPCEmu-*

# Local debug / scratch
/rpclog.txt
/hd4.hdf

